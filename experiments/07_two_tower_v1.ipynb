{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Two-Tower Contrastive Training (Week 1 Milestone)\n",
    "\n",
    "This notebook trains the `TwoTowerAnomalyModel` by aligning the Sensor Tower and Visual Tower representations using the Normalized Temperature-scaled Cross Entropy (NT-Xent) contrastive loss."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import sys\n",
    "import torch\n",
    "from torch.utils.data import DataLoader\n",
    "\n",
    "# Add backend to path\n",
    "sys.path.append(os.path.abspath('../backend'))\n",
    "\n",
    "from app.models.two_tower import TwoTowerAnomalyModel\n",
    "from app.training.trainer import TwoTowerContrastiveTrainer\n",
    "from app.training.eval import EmbeddingVisualizer\n",
    "from app.data.pair_dataset import PairDataset"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Setup Mock Datasets\n",
    "For this experiment, we'll create mock datasets that mimic the output of `MIMIIDataset` and `MVTecDataset`."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from torch.utils.data import Dataset\n",
    "\n",
    "class MockSensorDataset(Dataset):\n",
    "    def __init__(self, num_samples=100, channels=14, seq_len=50):\n",
    "        self.data = torch.randn(num_samples, channels, seq_len)\n",
    "        self.labels = torch.randint(0, 2, (num_samples,))\n",
    "        \n",
    "    def __len__(self):\n",
    "        return len(self.data)\n",
    "        \n",
    "    def __getitem__(self, idx):\n",
    "        return self.data[idx], self.labels[idx]\n",
    "\n",
    "class MockVisualDataset(Dataset):\n",
    "    def __init__(self, num_samples=100, img_size=224):\n",
    "        self.data = torch.randn(num_samples, 3, img_size, img_size)\n",
    "        self.labels = torch.randint(0, 2, (num_samples,))\n",
    "        \n",
    "    def __len__(self):\n",
    "        return len(self.data)\n",
    "        \n",
    "    def __getitem__(self, idx):\n",
    "        return self.data[idx], None, self.labels[idx]\n",
    "\n",
    "print(\"Initializing Mock Datasets...\")\n",
    "sensor_train = MockSensorDataset(num_samples=200)\n",
    "visual_train = MockVisualDataset(num_samples=200)\n",
    "\n",
    "sensor_val = MockSensorDataset(num_samples=50)\n",
    "visual_val = MockVisualDataset(num_samples=50)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Initialize PairDataset and DataLoader"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "pair_train = PairDataset(sensor_train, visual_train)\n",
    "pair_val = PairDataset(sensor_val, visual_val)\n",
    "\n",
    "train_loader = DataLoader(pair_train, batch_size=32, shuffle=True)\n",
    "val_loader = DataLoader(pair_val, batch_size=32, shuffle=False)\n",
    "\n",
    "print(f\"Train pairs: {len(pair_train)}\")\n",
    "print(f\"Val pairs: {len(pair_val)}\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Initialize Model and Trainer"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "print(f\"Using device: {device}\")\n",
    "\n",
    "# 14 sensor channels for CMAPSS, embedding dim 256\n",
    "model = TwoTowerAnomalyModel(sensor_input_dim=14, embed_dim=256, freeze_visual=True)\n",
    "\n",
    "trainer = TwoTowerContrastiveTrainer(\n",
    "    model=model,\n",
    "    train_loader=train_loader,\n",
    "    val_loader=val_loader,\n",
    "    epochs=5,\n",
    "    sensor_lr=3e-4,\n",
    "    visual_lr=1e-4,\n",
    "    device=device,\n",
    "    checkpoint_dir=\"../backend/checkpoints/two_tower\"\n",
    ")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Run Joint Training Loop"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "trainer.train()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Evaluate and Plot t-SNE"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "visualizer = EmbeddingVisualizer(model, val_loader, device=device)\n",
    "visualizer.plot_tsne(save_path=\"../docs/assets/tsne_week1.png\")"
   ]
  }
 ],
